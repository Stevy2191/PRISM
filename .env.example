DB_HOST=mariadb
DB_PORT=3306
DB_NAME=prism
DB_USER=prism
DB_PASSWORD=changeme

# LDAP / Active Directory — OPTIONAL.
# These values are only used when a user clicks "Active Directory" on the login page.
# If you don't use AD, leave these as stubs (placeholder values) — the backend starts
# fine and only local account login will work. Run setup.sh to configure interactively.
LDAP_URL=ldap://your-dc.domain.local
LDAP_BASE_DN=DC=domain,DC=local
LDAP_BIND_DN=CN=svc-prism,OU=Service Accounts,DC=domain,DC=local
LDAP_BIND_PASSWORD=changeme
LDAP_USER_FILTER=(sAMAccountName={{username}})

SESSION_SECRET=changeme
NODE_ENV=production

# --- Optional extras ---
# Root password for the MariaDB container (compose only).
DB_ROOT_PASSWORD=rootchangeme

# Bootstrap local admin — created automatically on first migration if a user with
# this username does not already exist. It is a real local account (admin role).
# Consider deleting this account once other admin accounts are set up.
BOOTSTRAP_LOCAL_USERNAME=admin
BOOTSTRAP_LOCAL_PASSWORD=changeme

# Where ticket attachments are stored inside the backend container (volume mount).
UPLOAD_DIR=/uploads

# Host port PRISM is served on. Change this if port 80 is already in use.
APP_PORT=8080

# Set to "true" only when serving over HTTPS (e.g. behind a TLS-terminating proxy).
# Leave as "false" for plain HTTP deployments — browsers refuse to send Secure
# cookies over HTTP (except localhost), which breaks authentication.
COOKIE_SECURE=false

# Allowed CORS origin(s) for the API, comma-separated. Only needed when the
# frontend is served from a different origin than the backend (e.g. a separate
# dev server hitting the backend directly). In the standard Docker Compose setup
# the nginx reverse proxy makes all requests same-origin, so leave this unset.
# CORS_ORIGIN=http://localhost:8080
