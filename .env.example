DB_HOST=mariadb
DB_PORT=3306
DB_NAME=prism
DB_USER=prism
DB_PASSWORD=changeme
LDAP_URL=ldap://your-dc.domain.local
LDAP_BASE_DN=DC=domain,DC=local
LDAP_BIND_DN=CN=svc-prism,OU=Service Accounts,DC=domain,DC=local
LDAP_BIND_PASSWORD=changeme
LDAP_USER_FILTER=(sAMAccountName={{username}})
SESSION_SECRET=changeme
NODE_ENV=production

# --- Optional extras ---
# Root password for the MariaDB container (compose only).
DB_ROOT_PASSWORD=rootchangeme

# Bootstrap admin — the single local account allowed before any AD user is
# promoted to admin. Use it for first login, then assign roles and remove it.
BOOTSTRAP_ADMIN_USERNAME=prismadmin
BOOTSTRAP_ADMIN_PASSWORD=changeme
BOOTSTRAP_ADMIN_EMAIL=admin@domain.local

# Where ticket attachments are stored inside the backend container (volume mount).
UPLOAD_DIR=/uploads

# Set to "false" to allow non-HTTPS session cookies in production (e.g. behind
# a TLS-terminating proxy that forwards plain HTTP). Defaults to secure cookies.
COOKIE_SECURE=true
